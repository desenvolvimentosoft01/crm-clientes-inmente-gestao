generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusCliente {
  ativo
  em_implantacao
  inadimplente
  cancelado
}

enum ModuloSistema {
  ifood
  orcamentos
}

enum PlanoContrato {
  free
  mensal
  anual
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senhaHash String   @map("senha_hash")
  criadoEm  DateTime @default(now()) @map("criado_em")

  clientesCriados Cliente[]   @relation("ClienteCriadoPor")
  interacoes      Interacao[] @relation("InteracaoAutor")

  @@map("usuarios")
}

model Cliente {
  id               Int           @id @default(autoincrement())
  nome             String
  linkSite         String?       @map("link_site")
  contatoNome      String?       @map("contato_nome")
  contatoTelefone  String?       @map("contato_telefone")
  contatoEmail     String?       @map("contato_email")
  plano            PlanoContrato?
  valorMensal      Decimal?      @map("valor_mensal") @db.Decimal(10, 2)
  status           StatusCliente @default(ativo)
  modulos          ModuloSistema[]
  dataInicio       DateTime?     @map("data_inicio") @db.Date
  senhaSupabase    String?       @map("senha_supabase")
  observacoes      String?
  criadoPorId      Int?          @map("criado_por")
  criadoEm         DateTime      @default(now()) @map("criado_em")
  atualizadoEm     DateTime      @updatedAt @map("atualizado_em")

  criadoPor  Usuario?    @relation("ClienteCriadoPor", fields: [criadoPorId], references: [id])
  interacoes Interacao[]
  erros      ErroLog[]

  @@map("clientes")
}

model Interacao {
  id         Int      @id @default(autoincrement())
  clienteId  Int      @map("cliente_id")
  descricao  String
  autorId    Int?     @map("autor_id")
  criadoEm   DateTime @default(now()) @map("criado_em")

  cliente Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  autor   Usuario? @relation("InteracaoAutor", fields: [autorId], references: [id])

  @@index([clienteId])
  @@map("interacoes")
}

model ErroLog {
  id             Int      @id @default(autoincrement())
  clienteId      Int?     @map("cliente_id")
  clienteSite    String?  @map("cliente_site")
  mensagem       String
  detalheTecnico String?  @map("detalhe_tecnico")
  tela           String?
  tipo           String?
  usuario        String?
  diagnostico    String?  @map("diagnostico")
  ocorridoEm     DateTime? @map("ocorrido_em")
  criadoEm       DateTime @default(now()) @map("criado_em")

  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([clienteId])
  @@map("erros_log")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("push_subscriptions")
}
